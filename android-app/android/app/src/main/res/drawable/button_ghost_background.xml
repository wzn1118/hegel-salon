<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#1C1C1C" />
            <stroke
                android:width="1dp"
                android:color="@color/hegel_accent" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="#101010" />
            <stroke
                android:width="1dp"
                android:color="@color/hegel_border" />
        </shape>
    </item>
</selector>
