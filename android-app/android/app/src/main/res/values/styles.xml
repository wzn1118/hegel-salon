<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="android:windowBackground">@color/hegel_background</item>
        <item name="android:statusBarColor">@color/hegel_background</item>
        <item name="android:navigationBarColor">@color/hegel_background</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
    </style>

    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:background">@drawable/splash</item>
        <item name="postSplashScreenTheme">@style/AppTheme</item>
    </style>

    <style name="HegelToolbarTheme" parent="ThemeOverlay.AppCompat.Dark.ActionBar">
        <item name="colorControlNormal">@color/hegel_accent</item>
        <item name="android:textColorPrimary">@color/hegel_text</item>
        <item name="android:textColorSecondary">@color/hegel_muted_text</item>
    </style>

    <style name="HegelGhostButton" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/button_ghost_background</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/hegel_text</item>
        <item name="android:textSize">14sp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:paddingLeft">16dp</item>
        <item name="android:paddingRight">16dp</item>
    </style>

    <style name="HegelPrimaryButton" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/button_primary_background</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/hegel_text</item>
        <item name="android:textSize">14sp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:paddingLeft">16dp</item>
        <item name="android:paddingRight">16dp</item>
    </style>
</resources>
